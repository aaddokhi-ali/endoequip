# Copy this file to ".env.local" and fill in your real Firebase web config values.
# These are the PUBLIC web config keys (safe to expose in a browser app) — not secrets.
# Find them in: Firebase console > Project settings > General > Your apps > SDK setup/config

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
